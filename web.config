<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <!-- IIS local testing only: SSI for .html includes + extensionless URL rewrite.
       Form email uses the Node relay (api/form-server.js): run "npm run forms" on port 8787.
       To proxy /api/send-form through IIS, install URL Rewrite + ARR and uncomment the rule below.
       Production Linux uses deploy/nginx.conf instead. -->
  <system.webServer>
    <handlers>
      <add name="SSI-html" path="*.html" verb="GET,HEAD,POST" modules="ServerSideIncludeModule" resourceType="File" />
      <add name="SSI-htm" path="*.htm" verb="GET,HEAD,POST" modules="ServerSideIncludeModule" resourceType="File" />
    </handlers>
    <defaultDocument>
      <files>
        <clear />
        <add value="home.html" />
      </files>
    </defaultDocument>
    <rewrite>
      <rules>
<!-- BEGIN url-redirects -->
<!-- Auto-generated by detect-url-aliases.js -->
        <rule name="Redirect alias about-us/contact-us" stopProcessing="true">
          <match url="^about-us/contact-us/?$" ignoreCase="true" />
          <action type="Redirect" url="/contact-us" redirectType="Permanent" />
        </rule>
        <rule name="Redirect alias product-and-solutions" stopProcessing="true">
          <match url="^product-and-solutions/?$" ignoreCase="true" />
          <action type="Redirect" url="/products-and-solutions" redirectType="Permanent" />
        </rule>
        <rule name="Redirect alias valmont-tubing/brands/steel-tubing/astm-specs-testing" stopProcessing="true">
          <match url="^valmont-tubing/brands/steel-tubing/astm-specs-testing/?$" ignoreCase="true" />
          <action type="Redirect" url="/resources-and-specs/astm-specifications" redirectType="Permanent" />
        </rule>
        <rule name="Redirect alias valmont-tubing/brands/steel-tubing/finishes-chemistries" stopProcessing="true">
          <match url="^valmont-tubing/brands/steel-tubing/finishes-chemistries/?$" ignoreCase="true" />
          <action type="Redirect" url="/products-and-solutions/welded-steel-tubing/finishes-and-chemistries" redirectType="Permanent" />
        </rule>
        <rule name="Redirect alias valmont-tubing/brands/steel-tubing/tubing-solutions" stopProcessing="true">
          <match url="^valmont-tubing/brands/steel-tubing/tubing-solutions/?$" ignoreCase="true" />
          <action type="Redirect" url="/products-and-solutions/welded-steel-tubing/tubing-solutions" redirectType="Permanent" />
        </rule>
        <rule name="Redirect alias valmont-tubing/brands/steel-tubing/value-added-services" stopProcessing="true">
          <match url="^valmont-tubing/brands/steel-tubing/value-added-services/?$" ignoreCase="true" />
          <action type="Redirect" url="/products-and-solutions/welded-steel-tubing/value-add-services" redirectType="Permanent" />
        </rule>
        <rule name="Redirect alias valmont-tubing/contact-us" stopProcessing="true">
          <match url="^valmont-tubing/contact-us/?$" ignoreCase="true" />
          <action type="Redirect" url="/contact-us" redirectType="Permanent" />
        </rule>
        <rule name="Redirect alias valmont-tubing/product-catalogs/steel-tubing" stopProcessing="true">
          <match url="^valmont-tubing/product-catalogs/steel-tubing/?$" ignoreCase="true" />
          <action type="Redirect" url="/product-catalogs/welded-steel-tubing" redirectType="Permanent" />
        </rule>
        <!-- END url-redirects -->
        <!-- Uncomment when IIS ARR is installed and "npm run forms" is running:
        <rule name="Proxy form relay to Node" stopProcessing="true">
          <match url="^api/send-form/?$" ignoreCase="true" />
          <action type="Rewrite" url="http://127.0.0.1:8787/api/send-form" />
        </rule>
        -->

        <!-- Optional: redirect /page.html -> /page for clean URLs -->
        <rule name="Redirect .html to extensionless" stopProcessing="true">
          <match url="^(.*)\.html$" ignoreCase="true" />
          <conditions>
            <add input="{REQUEST_METHOD}" pattern="^GET$" />
            <add input="{REQUEST_URI}" pattern="^/shared/" negate="true" />
          </conditions>
          <action type="Redirect" url="{R:1}" redirectType="Permanent" />
        </rule>

        <!-- Serve extensionless URLs from matching .html files -->
        <rule name="Rewrite extensionless to .html" stopProcessing="true">
          <match url="^(.*)$" ignoreCase="true" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}.html" matchType="IsFile" />
          </conditions>
          <action type="Rewrite" url="{R:1}.html" />
        </rule>
      </rules>
    </rewrite>
    <httpErrors errorMode="Detailed" />
  </system.webServer>
</configuration>
