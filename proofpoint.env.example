# Copy to .env and fill in credentials. Do not commit .env.
PROOFPOINT_DefaultSenderEmailAddress=webmaster@valmont.com
PROOFPOINT_DefaultSenderName=Valmont Industries
PROOFPOINT_Host=smtp-us.ser.proofpoint.com
PROOFPOINT_Port=587
PROOFPOINT_UseAuthentication=True
PROOFPOINT_Username=
PROOFPOINT_Password=
PROOFPOINT_UseSSL=true
FORMS_SERVER_PORT=8787

# Shared admin editor
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=change-me-to-a-long-random-secret
ADMIN_HOSTS=stage.valmont.it

# Azure Blob image uploads. Prefer a container-scoped SAS URL with write/create permissions.
AZURE_BLOB_CONTAINER_SAS_URL=https://<account>.blob.core.windows.net/<container>?<sas-token>

# Alternative Blob settings if not using AZURE_BLOB_CONTAINER_SAS_URL:
# AZURE_STORAGE_ACCOUNT=<account>
# AZURE_BLOB_CONTAINER=<container>
# AZURE_STORAGE_SAS_TOKEN=<sas-token>
